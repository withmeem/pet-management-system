<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane prefHeight="600.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="petmanagement2025.HistoryController">
    <left>
        <VBox spacing="10" style="-fx-background-color: #f0f0f0; -fx-padding: 10;">
            <Button text="Dashboard" onAction="#showDashboard" maxWidth="Infinity"/>
            <Button text="Add Pet" onAction="#showAddPet" maxWidth="Infinity"/>
            <Button text="Pet List" onAction="#showPetList" maxWidth="Infinity"/>
            <Button text="Delete Pet" onAction="#showDeletePet" maxWidth="Infinity"/>
            <Button text="History" onAction="#showHistory" maxWidth="Infinity"/>
            <Button text="Logout" onAction="#handleLogout" maxWidth="Infinity"/>
        </VBox>
    </left>
    
    <center>
        <VBox spacing="20">
            <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
            
            <Label text="Activity History" style="-fx-font-size: 24px;"/>
            
            <TableView fx:id="historyTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="timeColumn" text="Time" prefWidth="200"/>
                    <TableColumn fx:id="actionColumn" text="Action" prefWidth="400"/>
                </columns>
            </TableView>
        </VBox>
    </center>
</BorderPane>